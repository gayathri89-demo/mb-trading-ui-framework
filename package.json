{
  "name": "mb-trading-ui-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "test": "cypress run",
    "report:merge": "mochawesome-merge \"cypress/reports/mochawesome/*.json\" -o cypress/reports/merged.json",
    "report:generate": "marge cypress/reports/merged.json -f report -o cypress/reports",
    "test:report": "npm run test && npm run report:merge && npm run report:generate",
    "test:chrome": "cypress run --browser chrome",
    "test:edge": "cypress run --browser edge",
    "test:firefox": "cypress run --browser firefox",
    "test:navigation": "cypress run --spec \"cypress/e2e/navigation/**/*.cy.js\"",
    "test:trading": "cypress run --spec \"cypress/e2e/trading/**/*.cy.js\"",
    "test:content": "cypress run --spec \"cypress/e2e/content/**/*.cy.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "cypress": "^15.13.0",
    "cypress-multi-reporters": "^2.0.5",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
